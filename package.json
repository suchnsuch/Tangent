{
	"name": "tangent-public",
	"version": "0.1.0",
	"description": "The Tangent Project's monorepo",
	"repository": "https://github.com/suchnsuch/tangent-public",
	"type": "module",
	"scripts": {
		"test": "npm run test --workspaces --if-present",
		"build": "npm run build --workspaces --if-present",
		"build:tangent-electron": "npm run build --workspace=lib/typewriter --workspace=packages/tangent-query-parser --workspace=packages/tangent-html-to-markdown --workspace=apps/tangent-electron"
	},
	"author": "Taylor Hadden",
	"license": "Apache-2.0",
	"workspaces": [
		"lib/typewriter",
		"packages/tangent-query-parser",
		"packages/tangent-html-to-markdown",
		"apps/tangent-electron",
		"apps/tangent-website",
		"apps/tangent-test-workspace-generator"
	],
	"devDependencies": {
		"@vitest/browser": "^4.0.16",
		"vitest": "^4.0.16"
	}
}
